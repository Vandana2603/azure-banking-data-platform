# profiles.yml.example
# Copy to ~/.dbt/profiles.yml and fill in real values (or use env vars, as
# shown here). Never commit a real profiles.yml with credentials to git.

bank_analytics:
  target: dev
  outputs:
    dev:
      type: sqlserver
      driver: "ODBC Driver 18 for SQL Server"
      server: "{{ env_var('AZURE_SQL_SERVER') }}"
      port: 1433
      database: "{{ env_var('AZURE_SQL_DATABASE') }}"
      schema: dw
      user: "{{ env_var('AZURE_SQL_USER') }}"
      password: "{{ env_var('AZURE_SQL_PASSWORD') }}"
      encrypt: true
      trust_cert: false
      threads: 4
