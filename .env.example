# Copy this file to .env and fill in real values.
# NEVER commit a real .env file - it is already in .gitignore.

AZURE_SQL_SERVER=bank-sql-server.database.windows.net
AZURE_SQL_DATABASE=BankAnalyticsDW
AZURE_SQL_USER=your_sql_admin_user
AZURE_SQL_PASSWORD=your_sql_admin_password

# Only needed if using the optional local SQL Server container in docker-compose.yml
MSSQL_SA_PASSWORD=YourStrong@Passw0rd

# Databricks (only needed for real Azure deployment, not local Docker runs)
DATABRICKS_HOST=https://adb-xxxxxxxxxxxxxxx.x.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_pat_token
